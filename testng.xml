<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserSuite" parallel="tests" thread-count="4">
    <parameter name="headless" value="true"/>

    <!-- Chrome -->
    <test name="ChromeTest">
        <parameter name="browser" value="chrome"/>
        <parameter name="headless" value="true"/>
        <parameter name="executionType" value="local"/>
        <classes>
            <class name="tests.ProductBrowsingTests"/>
            <class name="tests.ProductDetailsTests"/>
            <class name="tests.ProductSearchTests"/>
            <class name="tests.ProductFilterTests"/>
            <class name="tests.HeaderNavigationTests"/>
            <class name="tests.LoginTests"/>
            <class name="tests.CartTest"/>
            <class name="tests.RegisterTest"/>
        </classes>
    </test>

    <!-- Edge -->
    <test name="EdgeTest">
        <parameter name="browser" value="edge"/>
        <parameter name="headless" value="true"/>
        <parameter name="executionType" value="local"/>
        <classes>
            <class name="tests.ProductBrowsingTests"/>
            <class name="tests.ProductDetailsTests"/>
            <class name="tests.ProductSearchTests"/>
            <class name="tests.ProductFilterTests"/>
            <class name="tests.HeaderNavigationTests"/>
            <class name="tests.LoginTests"/>
            <class name="tests.CartTest"/>
            <class name="tests.RegisterTest"/>
        </classes>
    </test>

